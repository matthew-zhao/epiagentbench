{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/epiagentbench/episode.schema.json",
  "title": "EpiAgentBench public episode manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "schema_version",
    "role",
    "start_time",
    "deadline",
    "initial_alert_ids",
    "objectives",
    "budgets",
    "enabled_tools"
  ],
  "properties": {
    "episode_id": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "role": {"type": "string", "minLength": 1},
    "start_time": {"type": "string", "format": "date-time"},
    "deadline": {"type": "string", "format": "date-time"},
    "initial_alert_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "validate_signal",
          "investigate",
          "forecast_growth",
          "intervene",
          "review_response",
          "respond",
          "handoff"
        ]
      },
      "uniqueItems": true
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_calls",
        "analyst_minutes",
        "operational_credits",
        "privacy_units"
      ],
      "properties": {
        "tool_calls": {"type": "integer", "minimum": 1},
        "analyst_minutes": {"type": "integer", "minimum": 1},
        "operational_credits": {"type": "integer", "minimum": 0},
        "privacy_units": {"type": "integer", "minimum": 0}
      }
    },
    "policy_pack": {"type": "string"},
    "enabled_tools": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "uniqueItems": true
    }
  }
}
